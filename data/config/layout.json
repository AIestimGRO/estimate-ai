{
  "header_scan": {
    "max_rows": 50,
    "max_cols": 60,
    "min_matched_fields": 2
  },
  "data_scan": {
    "max_blank_run": 5
  },
  "field_priority": ["base_price", "unit", "work_name", "section", "code"],
  "fields": {
    "base_price": {
      "mode": "contains",
      "patterns": [
        "цена единицы работ",
        "цена единицы",
        "цена за ед",
        "цена за единиц",
        "стоимость единицы",
        "стоимость за ед",
        "стоимость за единиц",
        "базовая цена",
        "цена за 1"
      ]
    },
    "unit": {
      "mode": "contains",
      "patterns": [
        "ед изм",
        "единица измер",
        "единицы измер"
      ]
    },
    "work_name": {
      "mode": "startswith",
      "patterns": [
        "наименование работ",
        "наименование",
        "работы"
      ]
    },
    "section": {
      "mode": "contains",
      "patterns": [
        "код раздела"
      ]
    },
    "code": {
      "mode": "contains",
      "patterns": [
        "перечень гэсн",
        "перечень",
        "обоснование",
        "шифр",
        "код"
      ]
    }
  },
  "coefficient": {
    "value_cell": "D20",
    "region_label": {
      "mode": "contains",
      "patterns": ["регион"]
    },
    "coefficient_label": {
      "mode": "contains",
      "patterns": ["коэффициент", "коэфф"]
    }
  },
  "catalog": {
    "header_scan": {
      "max_rows": 10,
      "max_cols": 25,
      "min_matched_fields": 3
    },
    "data_start_offset": 1,
    "field_priority": [
      "added_date",
      "code",
      "task_id",
      "price",
      "unit",
      "work_name",
      "region"
    ],
    "fields": {
      "task_id": {
        "mode": "contains",
        "patterns": ["номер задачи"]
      },
      "work_name": {
        "mode": "startswith",
        "patterns": ["наименование"]
      },
      "unit": {
        "mode": "contains",
        "patterns": ["ед изм", "единица измер", "единицы измер"]
      },
      "price": {
        "mode": "contains",
        "patterns": [
          "цена единицы работ",
          "цена единицы",
          "базовая цена"
        ]
      },
      "code": {
        "mode": "contains",
        "patterns": ["перечень гэсн", "перечень", "обоснование"]
      },
      "region": {
        "mode": "equals",
        "patterns": ["регион"]
      },
      "added_date": {
        "mode": "contains",
        "patterns": ["дата добавления", "дата добав"]
      }
    }
  }
}
